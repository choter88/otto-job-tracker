# Local development / offline-host example configuration
#
# Never commit real secrets or production patient data to Git.

# Database (SQLite file stored locally)
# - If not set, defaults to `$OTTO_DATA_DIR/otto.sqlite`.
OTTO_SQLITE_PATH=.otto-data/otto.sqlite

# Sessions
SESSION_SECRET=change-me-to-a-long-random-string

# Server
PORT=5150
# Use `0.0.0.0` to allow other computers on the LAN to connect to the Host (SOT).
# Use `127.0.0.1` to restrict to a single machine.
OTTO_LISTEN_HOST=0.0.0.0

# Desktop/offline guardrails
# - OTTO_AIRGAP=true disables *all* outbound integrations (recommended for HIPAA/offline).
OTTO_AIRGAP=true
OTTO_DISABLE_SMS=true
OTTO_ENABLE_AI_SUMMARY=false
OTTO_ALLOW_PHI_EGRESS=false
OTTO_LAN_ONLY=true

# Licensing (Host only)
# - Defaults to `https://ottojobtracker.com` if not set.
# OTTO_LICENSE_BASE_URL=https://ottojobtracker.com
# If `OTTO_AIRGAP=true` and you need licensing in dev, allowlist the portal:
# OTTO_EGRESS_ALLOWLIST=ottojobtracker.com,www.ottojobtracker.com

# Cookies
# - For true LAN deployments, prefer HTTPS and keep this true.
# - For local HTTP dev (http://localhost), set false.
OTTO_COOKIE_SECURE=false

# Optional: persist logs/state under a known folder (use an absolute path for production installs)
OTTO_DATA_DIR=.otto-data

# Optional: file-based audit log retention (JSONL, no request/response payloads)
# OTTO_AUDIT_LOG_PATH=.otto-data/audit_log.jsonl
# OTTO_AUDIT_LOG_RETENTION_DAYS=30
# OTTO_AUDIT_LOG_MAX_BYTES=5242880

# Auto-update (desktop only, enabled by default)
# Set to false to disable checking for updates (e.g. in strict airgap environments).
# OTTO_AUTO_UPDATE=false

# GitHub personal access token (contents:read) for private repo auto-update.
# Required on build machines — electron-builder embeds it in the app so
# electron-updater can fetch releases from the private GitHub repo.
# GH_TOKEN=

# Sentry error reporting (leave blank to disable)
# SENTRY_DSN=
